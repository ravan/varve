VARVE_URL=http://127.0.0.1:8080
VARVE_DISPLAY_NAME=Local Varve

# Optional writer redirect allowlist. VARVE_URL's origin is always allowed.
# VARVE_ALLOWED_WRITER_ORIGINS=https://writer.example.com

# Optional BFF limits (defaults shown).
# VARVE_REQUEST_TIMEOUT_MS=60000
# VARVE_MAX_REQUEST_BYTES=1048576
